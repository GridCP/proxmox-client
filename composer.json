{
  "name": "gridcp/proxmox-client",
  "description": "HTTP client for the Proxmox VE API",
  "type": "library",
  "license": "mit",
  "autoload": {
    "psr-4": {
      "GridCP\\Proxmox_Client\\": "src/",
      "GridCP\\Proxmox\\Api\\": "src/v2"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "GridCP\\Proxmox_Client\\Tests\\": "tests/",
      "GridCP\\Proxmox\\Api\\Tests\\": "tests/v2"
    }
  },
  "authors": [
    {
      "name": "GridCP Team"
    }
  ],
  "require": {
    "php": "8.5.*",
    "lib-curl": "*",
    "symfony/dotenv": "8.0.*",
    "guzzlehttp/guzzle": "^7.8",
    "symfony/event-dispatcher": "8.0.*",
    "symfony/http-client": "8.0.*",
    "league/uri": "^7.5",
    "psr/http-client": "^1.0",
    "symfony/serializer": "^8.0",
    "symfony/property-access": "^8.0",
    "symfony/property-info": "^8.0",
    "php-http/discovery": "^1.20",
    "php-http/logger-plugin": "^1.5",
    "monolog/monolog": "^3.10",
    "symfony/console": "^8.0",
    "php-http/httplug": "^2.4"
  },
  "require-dev": {
    "phpunit/phpunit": "13.0.*",
    "friendsofphp/php-cs-fixer": "3.94.*",
    "ext-http": "*",
    "symfony/var-dumper": "^8.0"
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
