{
    "name": "gridcp/proxmox-client",
    "description": "HTTP client for the Proxmox VE API",
    "type": "library",
    "license": "mit",
    "autoload": {
        "psr-4": {
            "GridCP\\Proxmox_Client\\": "src/",
            "GridCP\\Proxmox\\Api\\": "src/v2"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GridCP\\Proxmox_Client\\Tests\\": "tests/",
            "GridCP\\Proxmox\\Api\\Tests\\": "tests/v2"
        }
    },
    "authors": [
        {
            "name": "GridCP Team"
        }
    ],
    "require": {
        "php": ">=8.2",
        "lib-curl": "*",
        "symfony/dotenv": "^6.4",
        "guzzlehttp/guzzle": "^7.8",
        "symfony/event-dispatcher": "^6.4",
        "symfony/http-client": "^6.4",
        "league/uri": "^7.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "friendsofphp/php-cs-fixer": "^3.87"
    }
}
