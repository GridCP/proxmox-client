{
    "name": "gridcp/proxmox-client",
    "description": "HTTP client for the Proxmox VE API",
    "type": "library",
    "license": "mit",
    "autoload": {
        "psr-4": {
            "GridCP\\Proxmox_Client\\": "src/",
            "GridCP\\Proxmox\\Api\\": "src/v2"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GridCP\\Proxmox_Client\\Tests\\": "tests/",
            "GridCP\\Proxmox\\Api\\Tests\\": "tests/v2"
        }
    },
    "authors": [
        {
            "name": "GridCP Team"
        }
    ],
    "require": {
        "php": "8.5.*",
        "lib-curl": "*",
        "symfony/dotenv": "8.0.*",
        "guzzlehttp/guzzle": "^7.8",
        "symfony/event-dispatcher": "8.0.*",
        "symfony/http-client": "8.0.*",
        "league/uri": "^7.5",
        "psr/http-client": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "13.0.*",
        "friendsofphp/php-cs-fixer": "3.94.*"
    }
}
